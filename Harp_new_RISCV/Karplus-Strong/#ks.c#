		E6,F6,F6s,G6,G6s,A6,A6s,B6};

// array for keeping track of our position in each buffer.
int16_t position[68] = {0};

// array for timeouts for each buffer.
int32_t timer[68] = {0};

// Plucking a string is simulated by filling the array with
// random numbers between -0.5 and +0.5. 
void ks_string_pluck(int16_t midi_num, int16_t volume)
{
  int index;
  int32_t tmp; // using 32 bits makes the multiply work
  int i;
  if((midi_num >= FIRST_MIDI)&&(midi_num <= LAST_MIDI))
    {
      index = midi_num - FIRST_MIDI;
      for(i=0;i<array_size[index];i++)
        {
          // Create a random S(15,16) between -0.5 and 0.5.
          // The implementation of rand() on SEGGER Embedded
          // Studio is not very good, so I use a version that
          // I wrote.
          tmp = myrand();
          tmp>>=17; // tmp is now an S(15,16) between -0.5 and 0.5
           // multiply by volume and convert to S(0,15)
           tmp = (volume * tmp)>>17;
           buffer[index][i] = tmp;  // store in buffer
        }
      timer[midi_num-FIRST_MIDI]=64*array_size[midi_num-FIRST_MIDI];
    }
}

void ks_play_1_ms(int16_t *data)
{
  static int32_t tmp_buffer[AUDIO_BUFFER_LENGTH]; // this function is not re-entrant
  int i,j;
  int32_t temp;
  int nextpos;
  int32_t value;
  int32_t fact = 0xFEEE;  // 0.995819091796875 as a U(0,16)
  int32_t cposition;
  int32_t csize;
  // clear the temporary buffer
  memset(tmp_buffer,0,sizeof(int32_t) * AUDIO_BUFFER_LENGTH);
  // generate another millsecond of sound for each active string,
  // adding them together in tmp_buffer.
  for(j = 0; j <= LAST_MIDI-FIRST_MIDI; j++)
    {
      if(timer[j] > 0)
	{
	  cposition = position[j];
	  csize = array_size[j];
	  //if(s->timer>0)
	  for(i=0; i < AUDIO_BUFFER_LENGTH; i++)
	    {
	      // update each active string and add its output to the sum
	      nextpos = (cposition+1) % csize;
	      // calculate value as an S(0,31) 
	      value=(fact*(buffer[j][cposition]+buffer[j][nextpos]))>>1;
	      value >>= 16;  // convert to S(0,15)
	      buffer[j][cposition] = value;
	      tmp_buffer[i] += value;
	      cposition = nextpos;
	    }
	  position[j] = cposition;
	  timer[j]--;
	}
    } 
  // copy the results from tmp_buffer to data.
  for(i=0; i < AUDIO_BUFFER_LENGTH; i++)
    {
      temp = tmp_buffer[i];
      // We know that temp is an S(16,15), but after summing all of
      // of the strings, it could be too large for the bit depth.
      // Shift right  and saturate to the bit depth.
      asm("ssat %0,#12,%1, asr #3"
	  : "=r" (temp)
	  : "r" (temp)
	  );
      // store the sample in output buffer
      data[i] = (int16_t)temp;
    }
}
