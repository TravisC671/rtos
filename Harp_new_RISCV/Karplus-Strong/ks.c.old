/* This code produces music using the Karplus-Strong algorithm.
   Author: Larry Pyeatt
   Date: 11-1-2012 (revised 9-6-2021)
   (C) All rights reserved

   This code uses the Karplus-Strong algorithm to simulate a
   stringed instrument.  It sounds similar to a harp.

*/
#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>
#include <time.h>
#include <math.h>
#include <limits.h>
#include <string.h>
#include <ks.h>

/* if note is a midi number, then the frequency is: 
   hz = 440*pow(2,(note-69.0)/12.0), and the array size needed is
   SAMPLE_RATE/Hz This lookup table translates midi numbers to the
   array size.  The first midi number is 21, which is A0 (A at
   octave 0).  The two lowest octaves take too much space, and the
   upper octaves become inaccurate, so we will take four octaves
   from the middle.
*/

int16_t array_size[] = {
		889,839,792,747,705,666,628,593,560,528,499,471,
		444,419,396,374,353,333,314,297,280,264,249,235,
		222,210,198,187,176,166,157,148,140,132,125,118,
		111,105,99,93,88,83,79,74,70,66,62,59,
		56,52,49,47,44,42,39,37,35,33,31,29,
		28,26,25};

// The Karplus-Strong buffers starting at midi note 28
#define FIRST_MIDI 28
#define LAST_MIDI 90

int16_t E1[889];
int16_t F1[839];
int16_t F1s[792];
int16_t G1[747];
int16_t G1s[705];
int16_t A1[666];
int16_t A1s[628];
int16_t B1[593];
int16_t C2[560];
int16_t C2s[528];
int16_t D2[499];
int16_t D2s[471];
int16_t E2[444];
int16_t F2[419];
int16_t F2s[396];
int16_t G2[374];
int16_t G2s[353];
int16_t A2[333];
int16_t A2s[314];
int16_t B2[297];
int16_t C3[280];
int16_t C3s[264];
int16_t D3[249];
int16_t D3s[235];
int16_t E3[222];
int16_t F3[210];
int16_t F3s[198];
int16_t G3[187];
int16_t G3s[176];
int16_t A3[166];
int16_t A3s[157];
int16_t B3[148];
int16_t C4[140];
int16_t C4s[132];
int16_t D4[125];
int16_t D4s[118];
int16_t E4[111];
int16_t F4[105];
int16_t F4s[99];
int16_t G4[93];
int16_t G4s[88];
int16_t A4[83];
int16_t A4s[79];
int16_t B4[74];
int16_t C5[70];
int16_t C5s[66];
int16_t D5[62];
int16_t D5s[59];
int16_t E5[56];
int16_t F5[52];
int16_t F5s[49];
int16_t G5[47];
int16_t G5s[44];
int16_t A5[42];
int16_t A5s[39];
int16_t B5[37];
int16_t C6[35];
int16_t C6s[33];
int16_t D6[31];
int16_t D6s[29];
int16_t E6[28];
int16_t F6[26];
int16_t F6s[25];

// an array of pointers to the buffers, so that we can access them
// as a 2D array.
int16_t *buffer[] = {
		E1,F1,F1s,G1,G1s,A1,A1s,B1,C2,C2s,D2,D2s,
		E2,F2,F2s,G2,G2s,A2,A2s,B2,C3,C3s,D3,D3s,
		E3,F3,F3s,G3,G3s,A3,A3s,B3,C4,C4s,D4,D4s,
		E4,F4,F4s,G4,G4s,A4,A4s,B4,C5,C5s,D5,D5s,
		E5,F5,F5s,G5,G5s,A5,A5s,B5,C6,C6s,D6,D6s,
		E6,F6,F6s};

// array for keeping track of our position in each buffer.
int16_t position[63] = {0};

// array for timeouts for each buffer.
int32_t timer[63] = {0};

// Plucking a string is simulated by filling the array with
// random numbers between -0.5 and +0.5. volume is an S(0,16).
void ks_string_pluck(int16_t midi_num, int16_t volume)
{
  int index;
  int32_t tmp;   // using 32 bits makes the multiply work
  int16_t tmp16;
  int i;
  if((midi_num >= FIRST_MIDI)&&(midi_num <= LAST_MIDI))
    {
      index = midi_num - FIRST_MIDI;
      for(i=0;i<array_size[index];i++)
        {
          // Create a random S(15,16) between -0.5 and 0.5.
          // Get a 32 bit random number.
          tmp = rand();
          // Convert the random number to S(15,16) between -0.5 and 0.5
          tmp16 = tmp & 0xFFFF;
          tmp16 >>= 2;
          // multiply by volume, convert to S(0,15) and store
          // in the string buffer.
          tmp = (volume * (int32_t)tmp16)>>16;
          buffer[index][i] = tmp;  // store in buffer
        }
      timer[midi_num-FIRST_MIDI]=24*array_size[midi_num-FIRST_MIDI];
    }
}

#ifdef GET_AUDIO_MIN_MAX
int min_smpl = INT_MAX;
int max_smpl = INT_MIN;
#endif
void ks_fill_buffer(int16_t *data)
{
  // This function is not re-entrant. tmp_buffer will hold the
  // total output from all active strings. Its contents will be
  // shifted right and saturated to produce the final audio data.
  static int32_t tmp_buffer[AUDIO_BUFFER_LENGTH];
  int i,j;
  int32_t temp;
  int nextpos;
  int32_t value;
  int32_t fact = 0xFEEE;  // 0.995819091796875 as a U(0,16)
  int32_t cposition;
  int32_t csize;
  // clear the temporary buffer
  memset(tmp_buffer,0,sizeof(int32_t) * AUDIO_BUFFER_LENGTH);
  // generate another millsecond of sound for each active string,
  // adding them together in tmp_buffer.
  for(j = 0; j <= LAST_MIDI-FIRST_MIDI; j++)
    {
      if(timer[j] > 0)
	 {
	   cposition = position[j];
	   csize = array_size[j];
	   for(i=0; i < AUDIO_BUFFER_LENGTH; i++)
	     {
	       // update each active string and add its output to the sum
 	      nextpos = (cposition+1) % csize;
 	      // calculate value as an S(0,31) 
 	      value=(fact*((int32_t)buffer[j][cposition] + 
                            (int32_t)buffer[j][nextpos])+1)>>1;
 	      value >>= 16;  // convert to S(0,15)
 	      buffer[j][cposition] = value;
 	      tmp_buffer[i] += value;
 	      cposition = nextpos;
 	    }
 	  position[j] = cposition;
 	  timer[j]--;
 	}
    } 
  // copy the results from tmp_buffer to data.
  for(i=0; i < AUDIO_BUFFER_LENGTH; i++)
    {
      temp = tmp_buffer[i];
      // store the sample in output buffer
      data[i] = (uint16_t)temp;
    }
}
