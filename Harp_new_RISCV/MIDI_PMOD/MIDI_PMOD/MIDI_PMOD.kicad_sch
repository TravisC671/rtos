	(text "Pin 1 of J3 provides 3.3V\nat maximum of 100mA.\nConnecting J4 to a separate\n5V supply can give more voltage\nand current to drive longer \nMIDI cables. J5 is a jumper \nthat allows selecting between\nthe 3.3V supply on Pin 1 of J3,\nor an external 5V supply on J4\nto drive the MIDI OUT."
		(exclude_from_sim no)
		(at 118.11 125.73 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "edcf005e-3d0f-4085-8bc1-f1d3398e0871")
	)
